# =============================================================================
# Variable names the app reads (see `src/shared/localDev.js`).
# Firebase / Google client libraries also honor `GOOGLE_APPLICATION_CREDENTIALS`
# when present (path to a service account JSON file on disk).
# =============================================================================
#
# LOCAL: copy to `functions/.env` (gitignored). `loadEnv.js` loads it on `npm start`
# and `npm run set-user-role`.
#
# CLOUD RUN (container service — not Firebase Cloud Functions): do not ship `.env`.
# Set env vars on the revision. For credentials:
#
#   1. Store the full service account JSON in Secret Manager (one secret version).
#   2. On the Cloud Run service: mount that secret as a **volume** (not as the raw
#      JSON in a plain env var — avoids huge env values and keeps the key off
#      `docker inspect` / process listings).
#   3. Set environment variable:
#        GOOGLE_APPLICATION_CREDENTIALS=/path/inside/container/to/the/mounted/file.json
#      Use the exact mount path you configure (Console shows it when you add the volume).
#
# `GOOGLE_CLOUD_PROJECT` is not secret; set it as a normal env var.
# =============================================================================

# Firebase / GCP project ID (Firebase Console → Project settings)
GOOGLE_CLOUD_PROJECT=your-firebase-project-id

# Path to service account JSON **on the filesystem** (file must exist before Admin SDK runs).
#
# Local: relative to `functions/` when you use ./local.json
GOOGLE_APPLICATION_CREDENTIALS=./local.json
#
# Cloud Run (example — replace with your mount path):
# GOOGLE_APPLICATION_CREDENTIALS=/secrets/firebase-adminsdk/key.json

# Comma-separated allowed browser origins (CORS)
CORS_ORIGINS=http://localhost:5173,https://your-production-domain.example
